# Backend miljövariabler (.env exempel)

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=din-superhemliga-nyckel

# Cloudinary
CLOUDINARY_CLOUD_NAME=din-cloudinary-cloud
CLOUDINARY_API_KEY=din-cloudinary-key
CLOUDINARY_API_SECRET=din-cloudinary-secret

# Frontend-url (för CORS, kommaseparerad lista för både prod och lokalt)
FRONTEND_URL=https://boulderingapp.vercel.app,http://localhost:5173

# Övrigt (lägg till vid behov)
# PORT=10000
# NODE_ENV=production
